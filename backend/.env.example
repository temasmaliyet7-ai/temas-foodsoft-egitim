# ============================================================
# Backend ortam değişkenleri.
# Bu dosyayı `.env` olarak kopyala ve değerleri doldur.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# .env DOSYASI GIT'E COMMIT EDILMEZ.
# ============================================================

# Supabase proje ayarları (Dashboard > Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# DİKKAT: service_role anahtarı — yalnızca sunucuda kalmalı, tarayıcıya ASLA gitmez!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...

# Storage bucket adı (004_storage.sql ile oluşturulan)
SUPABASE_STORAGE_BUCKET=training-pages

# JWT sırları — güçlü rastgele değerler üret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=degistir-bunu-uzun-rastgele-bir-deger
JWT_REFRESH_SECRET=degistir-bunu-baska-uzun-rastgele-bir-deger
COOKIE_SECRET=degistir-bunu-cerez-imzalama-sirri

# Token ömürleri
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Frontend origin (CORS) — Vite dev sunucusu
FRONTEND_ORIGIN=http://localhost:5173

# Sunucu
PORT=4000
NODE_ENV=development
